APP_NAME=HealthTrack # Application name
APP_ENV=local # Local assessment environment
# Generate this after copying to .env.
APP_KEY=
APP_DEBUG=true # Enable verbose local errors
APP_TIMEZONE=UTC # Default application timezone
APP_URL=http://localhost:8000 # Base application URL
DOCKER_APP_URL=http://localhost:8000 # Base URL exposed by Docker Nginx
NGINX_PORT=8000 # Host port mapped to the nginx service

APP_LOCALE=en # Default application locale
APP_FALLBACK_LOCALE=en # Fallback locale
APP_FAKER_LOCALE=en_US # Faker locale for local data

APP_MAINTENANCE_DRIVER=file # Local maintenance mode driver
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4 # Local PHP CLI worker count
BCRYPT_ROUNDS=12 # Password hashing cost for local use

LOG_CHANNEL=stack # Default application log channel
LOG_STACK=single # Channels included in the default stack
LOG_DEPRECATIONS_CHANNEL=null # Deprecation log sink
LOG_LEVEL=debug # Local log verbosity

DB_CONNECTION=mysql # Primary database driver
DB_HOST=mysql # Docker service name for MySQL
DB_PORT=3306 # Internal MySQL port
DB_DATABASE=healthtrack # Application database name
DB_USERNAME=healthtrack # Application database user
DB_PASSWORD=secret # Application database password

MYSQL_DATABASE=healthtrack # MySQL container database to initialize
MYSQL_USER=healthtrack # MySQL container app user
MYSQL_PASSWORD=secret # MySQL container app user password
MYSQL_ROOT_PASSWORD=root # MySQL root password for local Docker use

SESSION_DRIVER=file # Simple filesystem sessions for local setup
SESSION_LIFETIME=120 # Session lifetime in minutes
SESSION_ENCRYPT=false # Leave session payloads unencrypted locally
SESSION_PATH=/ # Session cookie path
SESSION_DOMAIN=null # Session cookie domain

BROADCAST_CONNECTION=log # Log broadcasts locally
FILESYSTEM_DISK=local # Local filesystem disk
QUEUE_CONNECTION=redis # Use Redis-backed queues
CACHE_STORE=redis # Use Redis-backed cache
CACHE_PREFIX=healthtrack # Cache key prefix

REDIS_CLIENT=phpredis # Preferred Redis PHP client
REDIS_HOST=redis # Docker service name for Redis
REDIS_PORT=6379 # Internal Redis port
# Leave blank unless you enable Redis auth locally.
REDIS_PASSWORD=
# Leave blank unless you secure the Docker Redis container.
DOCKER_REDIS_PASSWORD=

OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1 # Weather API base URL
OPEN_METEO_TIMEOUT=10 # Weather API timeout in seconds
OPEN_METEO_CACHE_TTL=3600 # Weather API cache TTL in seconds

NAGER_DATE_BASE_URL=https://date.nager.at/api/v3 # Holiday API base URL
NAGER_DATE_TIMEOUT=10 # Holiday API timeout in seconds
NAGER_DATE_CACHE_TTL=86400 # Holiday API cache TTL in seconds
NAGER_DATE_DEFAULT_COUNTRY_CODE=US # Default holiday lookup country

OPEN_FDA_BASE_URL=https://api.fda.gov # OpenFDA API base URL
OPEN_FDA_TIMEOUT=15 # OpenFDA API timeout in seconds
OPEN_FDA_CACHE_TTL=43200 # OpenFDA API cache TTL in seconds
OPEN_FDA_RATE_LIMIT_PER_MINUTE=240 # Soft application rate limit per minute

REST_COUNTRIES_BASE_URL=https://restcountries.com/v3.1 # Countries API base URL
REST_COUNTRIES_TIMEOUT=10 # Countries API timeout in seconds
REST_COUNTRIES_CACHE_TTL=604800 # Countries API cache TTL in seconds

WELLNESS_CHECK_IN_MAX_PER_DAY=3 # Max daily wellness check-ins
WELLNESS_MOOD_SCALE_MIN=1 # Lowest allowed mood value
WELLNESS_MOOD_SCALE_MAX=10 # Highest allowed mood value
WELLNESS_ALERT_MOOD_THRESHOLD=3 # Mood value that triggers alerts
WELLNESS_WEATHER_CORRELATION_ENABLED=true # Enable weather correlation features
WELLNESS_HOLIDAY_STRESS_FLAG_ENABLED=true # Enable holiday stress flags
WELLNESS_ANALYTICS_RETENTION_DAYS=90 # Analytics retention window in days

VITE_APP_NAME="${APP_NAME}" # Frontend app label
